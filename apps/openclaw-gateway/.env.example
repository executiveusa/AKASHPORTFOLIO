# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost
LOG_LEVEL=debug

# HERALD Configuration
HERALD_URL=http://localhost:4200
HERALD_API_KEY=your_herald_api_key_here

# WhatsApp Configuration
WHATSAPP_ENABLED=false
WHATSAPP_ACCOUNT_SID=your_twilio_account_sid
WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
WHATSAPP_PHONE_NUMBER=+1234567890
WHATSAPP_WEBHOOK_TOKEN=your_webhook_token

# Telegram Configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram

# Slack Configuration
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Discord Configuration
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_guild_id

# Database Configuration
DATABASE_PATH=./sessions.db

# Session Configuration
SESSION_EXPIRY_HOURS=24
MAX_HISTORY_MESSAGES=50
