# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL=https://akashportfolio-control-room.vercel.app
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=https://akashportfolio-control-room.vercel.app

# ── Google OAuth ───────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Legacy aliases (accepted as fallback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Role-based access ─────────────────────────────────────────
ALLOWED_EMAILS=
ADMIN_EMAILS=
OPERATOR_EMAILS=

# ── Internal secrets ──────────────────────────────────────────
CRON_SECRET=
WEBHOOK_SECRET=

# ── Tool policy ───────────────────────────────────────────────
ENABLE_DANGEROUS_TOOLS=false
TOOL_ALLOWLIST=read,status,search
DISABLE_EXTERNAL_SIDE_EFFECTS=true

# ── Supabase / Postgres ───────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=control_room
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=

# ── Dify ─────────────────────────────────────────────────────
DIFY_BASE_URL=
DIFY_API_KEY=

# ── Langfuse ─────────────────────────────────────────────────
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# ── Open WebUI ───────────────────────────────────────────────
OPEN_WEBUI_BASE_URL=

# ── Keycloak (infra only) ─────────────────────────────────────
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# ── oauth2-proxy (infra only) ─────────────────────────────────
OAUTH2_PROXY_PROVIDER=google
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
