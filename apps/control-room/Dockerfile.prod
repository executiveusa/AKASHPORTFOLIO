# Synthia 3.0 Control Room - Optimized Production Dockerfile
# Multi-stage build for minimal image size (~200MB)

# ============================================================================
# BUILD STAGE
# ============================================================================
FROM node:18-alpine AS builder

WORKDIR /build

# Install build dependencies
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev for build)
RUN npm install || npm ci || npm i

# Copy source code
COPY . .

# Build Next.js application
RUN npm run build

# ============================================================================
# RUNTIME STAGE
# ============================================================================
FROM node:18-alpine AS runtime

WORKDIR /app

# Install dumb-init for proper signal handling
RUN apk add --no-cache dumb-init curl

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001

# Copy package files
COPY package*.json ./

# Install only production dependencies
RUN npm install --production && \
    npm cache clean --force

# Copy built application from builder
COPY --from=builder --chown=nextjs:nodejs /build/.next ./.next
COPY --from=builder --chown=nextjs:nodejs /build/public ./public
COPY --from=builder --chown=nextjs:nodejs /build/node_modules ./node_modules

# Copy additional configs
COPY --chown=nextjs:nodejs .env.example* ./

# Set user
USER nextjs

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:3000/api/health || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

# Start application
CMD ["node_modules/.bin/next", "start"]

# ============================================================================
# METADATA
# ============================================================================
LABEL org.opencontainers.image.title="Synthia 3.0 Control Room"
LABEL org.opencontainers.image.description="Autonomous Digital CEO with Claude API, Supabase, and Agent Swarm"
LABEL org.opencontainers.image.version="3.0.0"
LABEL org.opencontainers.image.authors="Zero-Touch Engineer"
LABEL org.opencontainers.image.source="https://github.com/executiveusa/AKASHPORTFOLIO"
