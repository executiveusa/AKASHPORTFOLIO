# ── infra/.env.example
# Copy to infra/.env and fill all values before running docker compose.
# Never commit infra/.env to version control.

# ── Base domain (no protocol, no trailing slash) ──────────────
BASE_DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_DB=control_room
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DIFY_DB=dify
LANGFUSE_DB=langfuse

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_REALM=synthia
KEYCLOAK_HOSTNAME=keycloak.yourdomain.com

# ── oauth2-proxy ──────────────────────────────────────────────
OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=https://keycloak.yourdomain.com/realms/synthia
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=

# ── Dify ─────────────────────────────────────────────────────
DIFY_SECRET_KEY=

# ── Langfuse ─────────────────────────────────────────────────
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
