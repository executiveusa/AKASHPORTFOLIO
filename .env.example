# Environment Configuration for AKASHPORTFOLIO / Kupuri Media Sphere OS™
# Copy this file to .env.local and fill in actual values

# ========================================
# ORGO CLOUD INTEGRATION
# ========================================
ORGO_TOKEN=your_orgo_cloud_token_here

# ========================================
# GITHUB INTEGRATION
# ========================================
GITHUB_TOKEN=your_github_token_here

# ========================================
# CORE LLM
# ========================================
ANTHROPIC_API_KEY=
LITELLM_BASE_URL=http://localhost:8000
LITELLM_MASTER_KEY=

# ========================================
# MERCURY 2 INCEPTION API (primary voice engine)
# ========================================
MERCURY_API_KEY=
MERCURY_API_ENDPOINT=https://api.mercury.ai/v2

# ========================================
# PERSONA PLEX (voice persona routing)
# ========================================
PERSONA_PLEX_API_KEY=

# ========================================
# ELEVENLABS (fallback voice engine)
# ========================================
ELEVEN_LABS_API_KEY=

# Per-sphere voice ID overrides (leave blank to use defaults in mercury-voice.ts)
SPHERE_SYNTHIA_VOICE_ID=
SPHERE_ALEX_VOICE_ID=
SPHERE_CAZADORA_VOICE_ID=
SPHERE_FORJADORA_VOICE_ID=
SPHERE_SEDUCTORA_VOICE_ID=
SPHERE_CONSEJO_VOICE_ID=
SPHERE_DR_ECONOMIA_VOICE_ID=
SPHERE_DRA_CULTURA_VOICE_ID=
SPHERE_ING_TEKNOS_VOICE_ID=

# ========================================
# SUPABASE
# ========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# ========================================
# CRON SECURITY
# ========================================
CRON_SECRET=change-me-in-production

# ========================================
# APPLICATION
# ========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# OPTIONAL / LEGACY
# ========================================
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

# ========================================
# SECURITY NOTES
# ========================================
# - NEVER commit this file with real values
# - Always use .env.local for local development
# - Verify .env is in .gitignore
# - Rotate credentials if accidentally exposed to git
# - Use strong, unique tokens for each service
