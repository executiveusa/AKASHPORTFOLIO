# Environment Configuration for AKASHPORTFOLIO/Synthia 3.0
# Copy this file to .env and fill in actual values for your environment

# ========================================
# ORGO CLOUD INTEGRATION
# ========================================
# Orgo Cloud authentication token for remote command execution
ORGO_TOKEN=your_orgo_cloud_token_here

# ========================================
# GITHUB INTEGRATION (control-room)
# ========================================
# GitHub Personal Access Token for repo access
# Required scopes: repo, read:org
GITHUB_TOKEN=your_github_token_here

# ========================================
# LLM API KEYS
# ========================================
# Perplexity API for reasoning and research tasks
PERPLEXITY_API_KEY=your_perplexity_key_here

# Optional: Additional LLM providers
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ========================================
# APPLICATION SETTINGS
# ========================================
# Current environment (development, staging, production)
NODE_ENV=development

# Base URL for the application
BASE_URL=http://localhost:3000

# ========================================
# SECURITY NOTES
# ========================================
# - NEVER commit this file with real values
# - Always use .env.local for local development
# - Verify .env is in .gitignore
# - Rotate credentials if accidentally exposed to git
# - Use strong, unique tokens for each service
