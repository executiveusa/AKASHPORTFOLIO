# .gitignore for Kupuri Media CDMX Root

# Node dependencies
**/node_modules/
node_modules/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/
.vercel/

# Environment secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# OS Metadata
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
logs/
/tmp/

# Sub-repository Git folders (to prevent nesting issues)
# We want to keep the code but not the .git history of subdirs
# AKASHPORTFOLIO-main/.git/ 

# Private Secrets
secrets.md
