# .gitignore for Kupuri Media CDMX Root

# Node dependencies
**/node_modules/
node_modules/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/
.vercel/

# Environment secrets
.env
.env.local
master.env
secrets.md
.env.development.local
.env.test.local
.env.production.local
*.pem

# OS Metadata
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
logs/
/tmp/

# Sub-repository Git folders (to prevent nesting issues)
# We want to keep the code but not the .git history of subdirs
# AKASHPORTFOLIO-main/.git/ 

# Private Secrets + Deployment docs with credentials
secrets.md
BUILD_REPORT.md
DEPLOYMENT_GUIDE.md
DOCKER_AND_DEPLOYMENT.md
STAGE_7_COMPLETION.md
DEPLOY_NOW.md
EXECUTE_DEPLOY.txt
COOLIFY_DEPLOY.sh
DEPLOY_SYNTHIA.sh
DEPLOYMENT_SUMMARY.md
VERCEL_DEPLOYMENT_COMPLETE.md
.vercel
.env*.local

# Credential test scripts (never commit these)
test_*.ps1
test_*.py
check_*.py
GH_PAT*

# Binaries
*.exe
rustup-init*

# Editor + temp dirs
.vscode/
.git-temp/
.yarn/cache/
.yarn/unplugged/
